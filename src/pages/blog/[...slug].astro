---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content } = await post.render();

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="section post">
    <div class="container post__inner">
      <a href="/blog" class="post__back">← All posts</a>
      <div class="post__tags">
        {post.data.tags.map((t) => <span class="post-tag">{t}</span>)}
      </div>
      <h1>{post.data.title}</h1>
      <p class="post__meta">
        By {post.data.author} ·
        <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
      </p>
      <div class="post__body">
        <Content />
      </div>
    </div>
  </article>

  <CtaBanner />
</BaseLayout>

<style>
  .post__inner { max-width: 720px; margin: 0 auto; }
  .post__back { font-size: 0.9rem; font-weight: 600; }
  .post__tags { display: flex; gap: 0.5rem; margin: 1.25rem 0 0.5rem; }
  .post-tag {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ff-brand-dark);
    background: var(--ff-brand-soft);
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
  }
  .post__meta { color: var(--ff-muted); margin-bottom: 2rem; }
  .post__body :global(h2) { margin-top: 2rem; font-size: 1.5rem; }
  .post__body :global(p) { color: var(--ff-ink-soft); font-size: 1.08rem; }
  .post__body :global(ul) { color: var(--ff-ink-soft); }
  .post__body :global(a) { color: var(--ff-brand-dark); font-weight: 600; }
</style>
