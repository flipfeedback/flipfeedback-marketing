---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="The page you were looking for does not exist.">
  <section class="section text-center" style="padding:6rem 0;">
    <div class="container">
      <p class="eyebrow">404</p>
      <h1>We could not find that page</h1>
      <p class="lead mx-auto" style="text-align:center;">
        The link may be broken or the page may have moved. Let's get you back on track.
      </p>
      <div style="display:flex;gap:0.75rem;justify-content:center;margin-top:1.5rem;flex-wrap:wrap;">
        <a href="/" class="btn btn--primary">Back to home</a>
        <a href="/product" class="btn btn--ghost">Explore the product</a>
      </div>
    </div>
  </section>
</BaseLayout>
