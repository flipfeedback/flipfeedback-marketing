---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, APP } from '../config';

const channels = [
  { label: 'General', email: SITE.email, note: 'Questions about FlipFeedback or your account.' },
  { label: 'Support', email: SITE.supportEmail, note: 'Already a customer and need a hand? We are quick to reply.' },
  { label: 'Sales', email: 'sales@flipfeedback.com', note: 'Larger team or Enterprise needs? Let us talk.' },
];
---

<BaseLayout
  title="Contact"
  description="Get in touch with the FlipFeedback team. Questions, support, or sales, we are happy to help."
>
  <section class="section hero-lite">
    <div class="container text-center">
      <p class="eyebrow">Contact</p>
      <h1>Get in touch</h1>
      <p class="lead mx-auto" style="text-align:center;">
        We are a small team and we read everything. Send us a note and we will get back to
        you, usually within one business day.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top:1rem;">
    <div class="container contact">
      <div class="contact__form-wrap card">
        <h2>Send us a message</h2>
        <p style="color:var(--ff-muted);">
          This form opens your email client. Prefer to write directly? Use one of the
          addresses on the right.
        </p>
        <!--
          Static site: no backend. The form composes a mailto link with the entered
          details so it works without a server. The app handles real account workflows.
        -->
        <form id="contact-form">
          <label>
            Name
            <input type="text" name="name" required autocomplete="name" />
          </label>
          <label>
            Email
            <input type="email" name="email" required autocomplete="email" />
          </label>
          <label>
            Message
            <textarea name="message" rows="5" required></textarea>
          </label>
          <button type="submit" class="btn btn--primary">Open email to send</button>
        </form>
      </div>

      <aside class="contact__side">
        <h2>Other ways to reach us</h2>
        {
          channels.map((c) => (
            <div class="contact__channel">
              <h3>{c.label}</h3>
              <a href={`mailto:${c.email}`}>{c.email}</a>
              <p>{c.note}</p>
            </div>
          ))
        }
        <div class="contact__channel">
          <h3>Already a customer?</h3>
          <p>
            Sign in to manage your account and connected sources.
          </p>
          <a href={APP.signin} class="btn btn--ghost">Sign in to FlipFeedback</a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ contactEmail: SITE.email }}>
  const form = document.getElementById('contact-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const name = String(data.get('name') || '');
      const email = String(data.get('email') || '');
      const message = String(data.get('message') || '');
      const subject = encodeURIComponent(`Website enquiry from ${name}`);
      const body = encodeURIComponent(`${message}\n\n— ${name} (${email})`);
      window.location.href = `mailto:${contactEmail}?subject=${subject}&body=${body}`;
    });
  }
</script>

<style>
  .hero-lite {
    background: radial-gradient(1000px 400px at 50% -20%, var(--ff-brand-soft), transparent 60%);
  }
  .contact {
    display: grid;
    grid-template-columns: 1.3fr 0.9fr;
    gap: 2.5rem;
    align-items: start;
  }
  .contact__form-wrap h2 { margin-bottom: 0.5rem; }
  form { display: flex; flex-direction: column; gap: 1rem; margin-top: 1rem; }
  label { font-weight: 600; color: var(--ff-ink); font-size: 0.92rem; display: flex; flex-direction: column; gap: 0.4rem; }
  input, textarea {
    font: inherit;
    padding: 0.65rem 0.8rem;
    border: 1px solid var(--ff-line);
    border-radius: var(--ff-radius-sm);
    color: var(--ff-ink);
    background: var(--ff-surface);
  }
  input:focus, textarea:focus {
    outline: none;
    border-color: var(--ff-brand);
    box-shadow: 0 0 0 3px var(--ff-brand-soft);
  }
  form .btn { align-self: flex-start; }

  .contact__channel { margin-bottom: 1.5rem; }
  .contact__channel h3 { margin-bottom: 0.25rem; }
  .contact__channel p { color: var(--ff-muted); font-size: 0.95rem; margin-top: 0.25rem; }

  @media (max-width: 860px) {
    .contact { grid-template-columns: 1fr; }
  }
</style>
