---
// Inline SVG wordmark + glyph. Self-contained so it works on a static CDN.
interface Props {
  variant?: 'dark' | 'light';
}
const { variant = 'dark' }: Props = Astro.props;
const textColor = variant === 'light' ? '#ffffff' : 'var(--ff-ink)';
---

<a class="logo" href="/" aria-label="FlipFeedback home">
  <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
    <rect width="28" height="28" rx="8" fill="#0d9488" />
    <path
      d="M8 9.5h12M8 14h8M8 18.5h5"
      stroke="#fff"
      stroke-width="2.2"
      stroke-linecap="round"
    />
    <circle cx="20.5" cy="18" r="2.5" fill="#ccfbf1" />
  </svg>
  <span class="logo__text" style={`color:${textColor}`}>FlipFeedback</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
  }
  .logo:hover { text-decoration: none; }
  .logo__text {
    font-weight: 800;
    font-size: 1.2rem;
    letter-spacing: -0.03em;
  }
</style>
